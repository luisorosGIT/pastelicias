generator client {
  provider        = "prisma-client-js"
  // Permite que los `include` y `select` aniados se ejecuten como un solo
  // SQL JOIN en lugar de N+1 queries. Reduce roundtrips dramáticamente
  // cuando hay relaciones (ej. users + branches, recipes + items + ingredient).
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Negocio ──────────────────────────────────────────────────────────────────
model Business {
  id                     String   @id @default(uuid())
  name                   String
  ruc                    String?
  taxRate                Float    @default(18) // IGV configurable
  hideIngredientCosts    Boolean  @default(false)
  allowBulkInventoryEdit Boolean  @default(true)
  // URL del logo del negocio (mostrado en sidebar y tickets). Opcional.
  logoUrl                String?
  // True cuando el OWNER completó el wizard inicial post-signup.
  // Se usa para redirigir a /onboarding hasta que termine.
  onboardingCompleted    Boolean  @default(false)
  // Plan de suscripción SaaS. Define los límites de recursos (ver config/plans.ts).
  plan                   Plan     @default(FREE)
  // Fecha de expiración del periodo de prueba (30 días desde signup).
  // null = sin trial pendiente (típicamente porque ya está en PRO/BUSINESS pagado).
  // Cuando se cumple esta fecha y el plan sigue siendo FREE, se bloquean los POSTs.
  trialEndsAt            DateTime?
  createdAt              DateTime @default(now())

  branches Branch[]
  users    User[]
  supportConversations SupportConversation[]

  @@map("businesses")
}

// ─── Administradores del SaaS (Genimatech) ────────────────────────────────────
// Separado del User normal porque tiene un dominio distinto: no pertenece a un
// Business, ve la app desde el lado de la plataforma. Login propio con
// email+password (bcrypt), JWT con audience 'admin'.
model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  @@map("admins")
}

// ─── Reset password: códigos de 6 dígitos por email ───────────────────────────
// Genera un código numérico que expira en 15 min. Cuando el usuario verifica,
// marcamos `used=true` y devolvemos un short-lived token para que pueda cambiar
// su password en la siguiente request. No hay relación con User porque puede
// pedirse reset incluso si el email no existe (no leakeamos esa info).
model PasswordResetCode {
  id        String   @id @default(uuid())
  email     String
  code      String   // 6 dígitos numéricos
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, used])
  @@index([expiresAt])
  @@map("password_reset_codes")
}

// ─── Chat de soporte (Pro / Business) ─────────────────────────────────────────
// Una conversación por business. Mensajes de usuarios y respuestas del admin
// (Genimatech). Mientras no hay panel admin, las respuestas se hacen via
// inserción manual en la tabla o un endpoint protegido por env var.
model SupportConversation {
  id         String   @id @default(uuid())
  businessId String
  userId     String   // el OWNER que abrió el chat
  status     String   @default("OPEN") // OPEN | CLOSED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business         @relation(fields: [businessId], references: [id])
  user     User             @relation(fields: [userId], references: [id])
  messages SupportMessage[]

  @@index([businessId])
  @@index([status])
  @@map("support_conversations")
}

model SupportMessage {
  id             String   @id @default(uuid())
  conversationId String
  senderRole     String   // USER | ADMIN
  senderName     String?  // nombre visible (opcional)
  content        String   @db.Text
  isReadByUser   Boolean  @default(false) // true cuando el OWNER ya leyó (solo aplica a mensajes ADMIN)
  isReadByAdmin  Boolean  @default(false) // true cuando admin ya leyó (solo aplica a mensajes USER)
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("support_messages")
}

// ─── Sucursal ─────────────────────────────────────────────────────────────────
model Branch {
  id         String  @id @default(uuid())
  businessId String
  name       String
  address    String?
  phone      String?
  isActive   Boolean @default(true)

  business         Business          @relation(fields: [businessId], references: [id])
  users            User[]
  ingredients      Ingredient[]
  recipes          Recipe[]
  sales            Sale[]
  reservations     Reservation[]
  productions      Production[]
  wasteLogs        WasteLog[]
  purchases        Purchase[]
  inventoryCounts  InventoryCount[]

  @@map("branches")
}

// ─── Usuario ──────────────────────────────────────────────────────────────────
model User {
  id         String  @id @default(uuid())
  businessId String
  branchId   String? // null = OWNER con acceso global
  email      String  @unique
  fullName   String
  role       Role    @default(SELLER)
  isActive   Boolean @default(true)

  business Business @relation(fields: [businessId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  sales    Sale[]
  supportConversations SupportConversation[]

  @@map("users")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum Role {
  OWNER
  MANAGER
  SELLER
  INVENTORY
}

// ─── Insumo / Ingrediente ─────────────────────────────────────────────────────
model Ingredient {
  id               String      @id @default(uuid())
  branchId         String
  name             String
  unit             MeasureUnit
  presentationSize Float       // tamaño de 1 presentación en unidad base
  stock            Float       @default(0)
  minStock         Float
  unitCost         Float       // costo por unidad base
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  branch          Branch           @relation(fields: [branchId], references: [id])
  recipeItems     RecipeItem[]
  wasteLogs       WasteLog[]
  purchases       Purchase[]
  inventoryCounts InventoryCount[]

  @@map("ingredients")
}

// ─── Compra de insumo (alimenta el cálculo de CPP) ──────────────────────────
model Purchase {
  id           String   @id @default(uuid())
  branchId     String
  ingredientId String
  quantity     Float    // en unidad base
  unitCost     Float    // costo por unidad base en esta compra puntual
  totalCost    Float    // quantity * unitCost (denormalizado para historial)
  supplier     String?
  notes        String?
  createdAt    DateTime @default(now())

  branch     Branch     @relation(fields: [branchId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([ingredientId])
  @@index([branchId, createdAt])
  @@map("purchases")
}

// ─── Conteo físico de inventario (genera Merma automática si hay variación) ──
model InventoryCount {
  id            String   @id @default(uuid())
  branchId      String
  ingredientId  String
  expectedStock Float    // lo que el sistema dice que deberías tener (en unidad base)
  actualStock   Float    // lo que el usuario contó en el estante
  varianceQty   Float    // actualStock - expectedStock (negativo = merma)
  varianceCost  Float    // varianceQty * unitCost al momento del conteo
  notes         String?
  createdAt     DateTime @default(now())

  branch     Branch     @relation(fields: [branchId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([ingredientId])
  @@index([branchId, createdAt])
  @@map("inventory_counts")
}

enum MeasureUnit {
  KG
  G
  L
  ML
  UNIT
}

// ─── Receta ───────────────────────────────────────────────────────────────────
model Recipe {
  id          String         @id @default(uuid())
  branchId    String
  name        String
  category    RecipeCategory
  salePrice   Float
  // Stock de productos terminados disponibles para venta. Se incrementa cuando
  // se registra una Production y se decrementa al vender o desechar el producto.
  // La conversión de insumos → producto ocurre SOLO en producción (no en venta).
  stock       Int            @default(0)
  imageUrl    String?
  description String?
  isActive    Boolean        @default(true)
  // ── Producto de reventa ─────────────────────────────────────────────────────
  // Si `isResale = true`, el producto NO se fabrica desde insumos: se compra
  // ya hecho y se revende. En ese caso:
  //   - `items` está vacío (no hay BOM)
  //   - `purchaseCost` guarda el costo unitario de compra (equivale al CPP)
  //   - El stock se incrementa con "Registrar Compra de reventa" en vez de Producción
  isResale     Boolean @default(false)
  purchaseCost Float?  // costo unitario; obligatorio si isResale=true
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  branch      Branch       @relation(fields: [branchId], references: [id])
  items       RecipeItem[]
  productions Production[]
  saleItems   SaleItem[]
  wasteLogs   WasteLog[]

  @@map("recipes")
}

enum RecipeCategory {
  PANADERIA
  PASTELERIA
  BEBIDAS
  OTROS
}

// ─── Insumos de Receta (BOM) ──────────────────────────────────────────────────
model RecipeItem {
  id           String @id @default(uuid())
  recipeId     String
  ingredientId String
  quantity     Float  // en unidad base del ingrediente

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@map("recipe_items")
}

// ─── Venta ────────────────────────────────────────────────────────────────────
model Sale {
  id             String        @id @default(uuid())
  branchId       String
  userId         String
  type           SaleType      @default(SIMPLE)
  paymentMethod  PaymentMethod
  subtotal       Float
  taxAmount      Float
  total          Float
  amountReceived Float?        // solo Venta Avanzada
  change         Float?
  ticketCode     String        @unique @default(uuid())
  createdAt      DateTime      @default(now())

  branch Branch     @relation(fields: [branchId], references: [id])
  user   User       @relation(fields: [userId], references: [id])
  items  SaleItem[]

  @@map("sales")
}

enum SaleType {
  SIMPLE
  ADVANCED
}

enum PaymentMethod {
  CASH
  CARD
  YAPE_PLIN
}

// ─── Ítem de Venta ────────────────────────────────────────────────────────────
model SaleItem {
  id        String @id @default(uuid())
  saleId    String
  recipeId  String
  quantity  Int
  unitPrice Float

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@map("sale_items")
}

// ─── Reservación ──────────────────────────────────────────────────────────────
model Reservation {
  id           String            @id @default(uuid())
  branchId     String
  clientName   String
  phone        String
  deliveryDate DateTime
  details      String?
  recipeId     String?
  customProduct String?          // texto libre si no es receta registrada
  totalPrice   Float
  advance      Float             @default(0)
  status       ReservationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  IN_PROCESS
  READY
  DELIVERED
}

// ─── Producción ───────────────────────────────────────────────────────────────
model Production {
  id        String   @id @default(uuid())
  branchId  String
  recipeId  String
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@map("productions")
}

// ─── Merma / Desperdicio ─────────────────────────────────────────────────────
model WasteLog {
  id           String      @id @default(uuid())
  branchId     String
  type         WasteType
  ingredientId String?
  recipeId     String?
  quantity     Float
  cost         Float
  reason       WasteReason
  notes        String?
  createdAt    DateTime    @default(now())

  branch     Branch      @relation(fields: [branchId], references: [id])
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id])
  recipe     Recipe?     @relation(fields: [recipeId], references: [id])

  @@map("waste_logs")
}

enum WasteType {
  INGREDIENT
  PRODUCT
}

enum WasteReason {
  EXPIRY
  PHYSICAL_DAMAGE
  CONTAMINATION
  LOST_BROKEN
  SPILL
  OTHER
}
