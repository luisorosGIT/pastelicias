# ─── Base de datos ───────────────────────────────────────────────────────────
# Cadena de conexión directa a Supabase PostgreSQL (Pooler recomendado)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Cadena directa (para Prisma Migrate, NO pooler)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # Solo para el backend — nunca exponer al cliente

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Mismo JWT_SECRET configurado en Supabase Dashboard > Settings > API > JWT Secret
JWT_SECRET="super-secret-jwt-key"

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:4200"
